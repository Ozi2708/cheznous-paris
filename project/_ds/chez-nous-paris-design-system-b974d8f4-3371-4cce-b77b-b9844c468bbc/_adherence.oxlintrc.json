{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/recipe/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Bricolage Grotesque|DM Sans|DM Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Bricolage Grotesque, DM Sans, DM Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|vegan|vegetalien|low-carb|outline|info|gold|tag)$/]",
        "message": "<Badge> variant must be one of 'default' | 'vegan' | 'vegetalien' | 'low-carb' | 'outline' | 'info' | 'gold' | 'tag'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|icon|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, icon, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|gold)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:advisor|text|subtitle|key|ref|className|style|children)$/]",
        "message": "<InfoCard> doesn't accept that prop. Declared props: advisor, text, subtitle."
      },
      {
        "selector": "JSXOpeningElement[name.name='IngredientItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:quantity|unit|name|highlight|note|key|ref|className|style|children)$/]",
        "message": "<IngredientItem> doesn't accept that prop. Declared props: quantity, unit, name, highlight, note."
      },
      {
        "selector": "JSXOpeningElement[name.name='NutritionBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:kcal|lipides|glucides|proteines|key|ref|className|style|children)$/]",
        "message": "<NutritionBar> doesn't accept that prop. Declared props: kcal, lipides, glucides, proteines."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrepStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|text|html|key|ref|className|style|children)$/]",
        "message": "<PrepStep> doesn't accept that prop. Declared props: number, text, html."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|portions|tags|kcal|prepTime|cookTime|key|ref|className|style|children)$/]",
        "message": "<RecipeCard> doesn't accept that prop. Declared props: number, title, portions, tags, kcal, prepTime, cookTime."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|portions|title|dietTags|featureBadges|key|ref|className|style|children)$/]",
        "message": "<RecipeHeader> doesn't accept that prop. Declared props: number, portions, title, dietTags, featureBadges."
      },
      {
        "selector": "JSXOpeningElement[name.name='TipBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|text|compact|key|ref|className|style|children)$/]",
        "message": "<TipBox> doesn't accept that prop. Declared props: type, title, text, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='TipBox'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:variante|astuce|conseil|conservation|suggestion)$/]",
        "message": "<TipBox> type must be one of 'variante' | 'astuce' | 'conseil' | 'conservation' | 'suggestion'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
